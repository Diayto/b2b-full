# Core
PORT=8000
CORS_ORIGIN=http://localhost:3000
DB_FILE=app.db

# Instagram J4-S1 — Meta OAuth (optional; default off)
INSTAGRAM_LIVE_OAUTH_ENABLED=false
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=http://localhost:8000/api/connectors/instagram/oauth/callback
META_GRAPH_VERSION=v21.0
# 64 hex chars = 32 bytes AES-256 key (required when INSTAGRAM_LIVE_OAUTH_ENABLED=true)
INSTAGRAM_TOKEN_ENCRYPTION_KEY=
# Optional: override success redirect (defaults to CORS_ORIGIN + INSTAGRAM_OAUTH_FRONTEND_PATH)
# INSTAGRAM_OAUTH_FRONTEND_REDIRECT_BASE=http://localhost:3000
# INSTAGRAM_OAUTH_FRONTEND_PATH=/marketing/data

# Live pull (J4-S2) uses the same flags + token store as OAuth above.
