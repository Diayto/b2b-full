# Supabase (Task 1 — required for auth)
# Create a project at https://supabase.com and run SQL from ../../supabase/migrations/
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Packaged demo on dashboard/breakdown when cloud has no row (or on fetch errors). Default: off.
# Alternatively use in-app «Демо-сценарий» on the Data page (sessionStorage, no env).
# VITE_CHRONA_DEMO_PREVIEW=true

# Pitch build: quiet chrome + demo fallback if preview env is off.
# VITE_CHRONA_ACCELERATOR_DEMO=true

# Backend API (notifications, Instagram connector, ingestion)
VITE_API_BASE_URL=http://127.0.0.1:8000
